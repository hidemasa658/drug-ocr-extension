{
  "manifest_version": 3,
  "name": "ぞうさん薬局 - 薬名転写",
  "version": "0.5.0",
  "description": "お薬手帳の薬名転写、新患アンケート閲覧と薬局システムへの一括転写（多店舗対応・DOMマッピング設定経由）",
  "permissions": ["scripting", "sidePanel", "storage", "tabs"],
  "host_permissions": ["https://okusuri.duckdns.org/*", "https://*/*"],
  "action": {
    "default_title": "ぞうさん薬局 薬名転写"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
